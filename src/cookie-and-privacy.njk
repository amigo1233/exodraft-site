<script>
    window.addEventListener('DOMContentLoaded', function () {
        const KEY = 'cookie_consent_v1';
        const TS = 'cookie_consent_v1_ts';

        const stateEl = document.getElementById('consentStateText');
        const dateEl = document.getElementById('consentDateText');

        const changeLink = document.getElementById('cookieChangeLink');
        const withdrawLink = document.getElementById('cookieWithdrawLink');
        const sepEl = document.querySelector('.cp-sep'); // "|" разделитель рядом

        function getBanner() {
            return document.getElementById('cookieBanner');
        }

        function fmt(ts) {
            if (!ts) return '—';
            const d = new Date(Number(ts));
            if (Number.isNaN(d.getTime())) return '—';
            return d.toLocaleString('uk-UA', {
                year: 'numeric',
                month: 'long',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function openBanner() {
            const banner = getBanner();
            if (!banner) return;

            banner.hidden = false;
            banner.removeAttribute('hidden');
            // если у тебя баннер как модалка по центру
            banner.style.display = 'flex';
            banner.style.zIndex = '2000';
        }

        function hasConsent() {
            const v = localStorage.getItem(KEY);
            return v === 'accept';
        }

        function setWithdrawVisibility() {
            const show = hasConsent();
            if (withdrawLink) withdrawLink.style.display = show ? '' : 'none';
            // прячем и "|" если withdraw скрыт
            if (sepEl) sepEl.style.display = show ? '' : 'none';
        }

        function refresh() {
            const v = localStorage.getItem(KEY);
            const ts = localStorage.getItem(TS);

            if (stateEl) {
                if (v === 'accept') stateEl.textContent = 'Дозволено';
                else if (v === 'reject') stateEl.textContent = 'Відхилено';
                else stateEl.textContent = 'Відхилено';
            }

            if (dateEl) dateEl.textContent = fmt(ts);

            setWithdrawVisibility();
        }

        // init
        refresh();

        if (changeLink) {
            changeLink.addEventListener('click', function (e) {
                e.preventDefault();
                openBanner();
            });
        }

        if (withdrawLink) {
            withdrawLink.addEventListener('click', function (e) {
                e.preventDefault();

                if (typeof gtag === 'function') {
                    gtag('consent', 'update', { analytics_storage: 'denied', ad_storage: 'denied' });
                }

                try {
                    localStorage.setItem(KEY, 'reject');          
                    localStorage.setItem(TS, String(Date.now())); 
                } catch (err) { }

                refresh();

            });
        }

        // Если нажали Accept/Reject в баннере — обновляем состояние/дату на странице
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('[data-cookie]');
            if (!btn) return;

            const val = btn.getAttribute('data-cookie');
            if (val !== 'accept' && val !== 'reject') return;

            try { localStorage.setItem(TS, String(Date.now())); } catch (err) { }
            refresh();
        });
    });
</script>