<!doctype html>
<html lang="uk">

<head>
  <!-- Google tag (gtag.js) -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }

    gtag('consent', 'default', { analytics_storage: 'denied', ad_storage: 'denied' });
    gtag('js', new Date());
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7QNWPN6XGQ"></script>
  <script>
    gtag('config', 'G-7QNWPN6XGQ', { send_page_view: false });
  </script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ metaTitle or title }}</title>

  <meta name="description" content="{{ description or 'Exodraft — енергоефективні рішення для димовидалення, рекуперації тепла та промислових систем.' }}">

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">


  <!-- Твой CSS (ВАЖНО: абсолютный путь) -->
  <link rel="stylesheet" href="/css/styles.css">

  <!-- Favicon (ВАЖНО: абсолютный путь) -->
  <link rel="icon" type="image/png" href="/img/exo.png">
</head>

<body class="d-flex flex-column min-vh-100 {% if headerOffset %}has-header-offset{% endif %}">
  <div class="header-topline" aria-hidden="true"></div>
  {# Header общий для всех страниц #}
  {% include "header.njk" %}

  {# Контент конкретной страницы #}
  <main class="flex-grow-1">
    {{ content | safe }}
  </main>

  {# Footer общий для всех страниц #}
  {% include "footer.njk" %}

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Cookie banner (UA) -->
  <div id="cookieBanner" class="cookie-banner" hidden>
    <div class="cookie-banner__inner container">
      <div class="cookie-banner__content">
        <div class="cookie-banner__title">Ми використовуємо файли cookie</div>
        <div class="cookie-banner__text">
          Ми застосовуємо cookie для аналітики, щоб розуміти, які сторінки корисні та як покращити
          сайт.<br>
          Ви можете прийняти або відхилити аналітичні cookie.
          <a href="/cookie-and-privacy/" class="cookie-banner__link">Політика конфіденційності</a>.
        </div>
      </div>

      <div class="cookie-banner__actions">
        <button class="btn btn-light btn-sm cookie-btn" data-cookie="reject">Відхилити</button>
        <button class="btn btn-primary btn-sm cookie-btn" data-cookie="accept">Прийняти</button>
      </div>
    </div>
  </div>
  {# Если есть твой общий JS — раскомментируй и используй #}
  <script src="/js/main.js"></script>

</body>

</html>