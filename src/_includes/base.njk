<!doctype html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title or "Exodraft Ukraine – системи димовидалення та рекуперації тепла" }}</title>

  <!-- Bootstrap 5 CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">


  <!-- Твой CSS (ВАЖНО: абсолютный путь) -->
  <link rel="stylesheet" href="/css/styles.css">

  <!-- Favicon (ВАЖНО: абсолютный путь) -->
  <link rel="icon" type="image/png" href="/img/exo.png">
</head>

<body class="d-flex flex-column min-vh-100">

  {# Header общий для всех страниц #}
  {% include "header.njk" %}

  {# Контент конкретной страницы #}
  <main class="flex-grow-1">
    {{ content | safe }}
  </main>

  {# Footer общий для всех страниц #}
  {% include "footer.njk" %}

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  {# Если есть твой общий JS — раскомментируй и используй #}
  <script src="/js/main.js"></script>

</body>
</html>
